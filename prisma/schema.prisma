generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // 👈 МАНА ШУ ҚАТОР ЕТИШМАЯПТИ
}

model Settings {
  id           Int      @id @default(1)
  currentModel String   @default("llama-3.1-8b-instant")
  systemPrompt String   @db.Text
  isBotActive  Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model User {
  id             String   @id @default(uuid())
  telegramId     BigInt   @unique
  username       String?
  firstName      String?

  platform       String   @default("TELEGRAM")
  isPaused       Boolean  @default(false)
  isBlocked      Boolean  @default(false)

  personalPrompt String?  @db.Text
  personalModel  String?
  tokensUsed     Int      @default(0)

  createdAt      DateTime @default(now())
  lastSeen       DateTime @updatedAt
  lastActivityAt DateTime @default(now()) // Охирги марта қачон хабар ёзгани
  canMessageFirst Boolean  @default(true)  // Диана биринчи бўлиб ёза оладими?

  messages       Message[]
  chatLogs       ChatLog[]
  profile        UserProfile?

  @@index([telegramId])
}

model Message {
  id        String   @id @default(uuid())
  userId    String

  role      String
  content   String   @db.Text
  source    String   @default("telegram_bot")

  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
}

model ChatLog {
  id         String   @id @default(uuid())
  telegramId BigInt
  userId     String
  role       String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([telegramId])
  @@index([userId])
}

model UserProfile {
  id               String   @id @default(uuid())
  userId           String   @unique

  topicsDiscussed  Json
  personalityNotes String   @db.Text

  messageCount     Int      @default(0)

  updatedAt        DateTime @updatedAt

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
