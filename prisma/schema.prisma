generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // 👈 МАНА ШУ ҚАТОР ЕТИШМАЯПТИ
}

model Settings {
  id           Int      @id @default(1)
  currentModel String   @default("llama-3.1-8b-instant")
  systemPrompt String   @db.Text
  isBotActive  Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model User {
  id             String   @id @default(uuid())
  telegramId     BigInt   @unique
  username       String?
  firstName      String?

  platform       String   @default("TELEGRAM")
  isPaused       Boolean  @default(false)
  isBlocked      Boolean  @default(false)
  isTracking     Boolean  @default(false)
  isManualMode   Boolean  @default(false)
  personaMode    String   @default("auto")

  personalPrompt String?  @db.Text
  personalModel  String?
  tokensUsed     Int      @default(0)
  aiSummary      String?  @default("Идет сбор данных...")

  createdAt      DateTime @default(now())
  lastSeen       DateTime @updatedAt
  lastActivityAt DateTime @default(now()) // Охирги марта қачон хабар ёзгани
  canMessageFirst Boolean  @default(true)  // Диана биринчи бўлиб ёза оладими?

  messages       Message[]
  chatLogs       ChatLog[]
  profile        UserProfile?

  @@index([telegramId])
}

model Message {
  id        String   @id @default(uuid())
  userId    String

  role      String
  content   String   @db.Text
  source    String   @default("telegram_bot")

  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
}

model ChatLog {
  id         String   @id @default(uuid())
  telegramId BigInt
  userId     String
  role       String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([telegramId])
  @@index([userId])
}

model UserProfile {
  id               String   @id @default(uuid())
  userId           String   @unique

  topicsDiscussed  Json
  personalityNotes String   @db.Text

  messageCount     Int      @default(0)

  updatedAt        DateTime @updatedAt

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Диананинг хатолари ва ютуқларини йиғиб борувчи жадвал
model InteractionLog {
  id          String   @id @default(cuid())
  userId      String
  userMessage String   @db.Text // Йигитнинг гапи
  dianaReply  String   @db.Text // Диананинг жавоби
  isPositive  Boolean  // true = ютуқ (лайк), false = хато (бот деди)
  isAnalyzed  Boolean  @default(false) // Суддан ўтганми?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isAnalyzed])
}

// "Ички суд" орқали чиқарилган олтин қоидалар жадвали
model LearnedRule {
  id        String   @id @default(cuid())
  ruleText  String   @db.Text // Қоида матни
  isActive  Boolean  @default(true) // Диана бунга амал қиляптими?
  createdAt DateTime @default(now())

  @@index([isActive])
}
